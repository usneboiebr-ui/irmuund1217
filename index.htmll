<!DOCTYPE html>

<html lang="mn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Чиний хувьд...</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400;1,700&family=Dancing+Script:wght@600;700&family=Cormorant+Garamond:ital,wght@1,300;1,500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
:root {
--rose: #ff6b9d; --rose-light: #ffb3cc; --rose-deep: #c44569;
--cream: #fff0f5; --night: #0d0a1a; --night-mid: #16101f; --gold: #ffd6e0;
}
body { min-height: 100vh; background: var(--night); font-family: 'Playfair Display', serif; overflow-x: hidden; }

/* LOGIN */
#loginOverlay { position:fixed;inset:0;z-index:9999;background:var(–night);display:flex;align-items:center;justify-content:center;flex-direction:column; }
.login-stars { position:absolute;inset:0;pointer-events:none;overflow:hidden; }
.login-card { position:relative;z-index:2;background:rgba(255,255,255,0.04);border:1px solid rgba(255,180,200,0.25);border-radius:32px;padding:48px 44px 44px;width:340px;backdrop-filter:blur(24px);box-shadow:0 0 80px rgba(255,100,150,.15),0 0 200px rgba(180,60,120,.07),inset 0 0 50px rgba(255,150,180,.04);text-align:center;animation:cardIn 1s cubic-bezier(.23,1,.32,1) both; }
@keyframes cardIn { from{opacity:0;transform:translateY(50px) scale(.92)} to{opacity:1;transform:translateY(0) scale(1)} }
.login-icon { font-size:52px;margin-bottom:16px;animation:heartbeat 1.5s ease-in-out infinite;display:block; }
@keyframes heartbeat { 0%,100%{transform:scale(1)} 50%{transform:scale(1.18)} }
.login-title { font-family:‘Dancing Script’,cursive;font-size:26px;color:#fff;margin-bottom:6px; }
.login-sub { font-size:13px;color:rgba(255,180,200,.55);margin-bottom:32px;font-style:italic; }
.pin-container { display:flex;justify-content:center;gap:14px;margin-bottom:28px; }
.pin-dot { width:54px;height:54px;border-radius:16px;background:rgba(255,150,180,.07);border:1.5px solid rgba(255,150,180,.2);display:flex;align-items:center;justify-content:center;font-size:26px;color:#ff9db8;transition:all .2s; }
.pin-dot.filled { background:rgba(255,107,157,.15);border-color:rgba(255,107,157,.5);box-shadow:0 0 16px rgba(255,107,157,.2); }
.numpad { display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px; }
.num-btn { height:52px;border-radius:14px;background:rgba(255,150,180,.07);border:1px solid rgba(255,150,180,.15);color:rgba(255,230,238,.9);font-size:20px;font-family:‘Playfair Display’,serif;cursor:pointer;transition:all .15s; }
.num-btn:hover { background:rgba(255,107,157,.15);border-color:rgba(255,107,157,.4);transform:scale(1.05); }
.num-btn:active { transform:scale(.96); }
.num-btn.del { font-size:16px;color:rgba(255,150,180,.7); }
.num-btn.empty { pointer-events:none;background:transparent;border:none; }
.login-error { font-family:‘Dancing Script’,cursive;font-size:15px;color:#ff6b9d;min-height:22px;transition:opacity .3s; }
.shake { animation:shake .4s ease both; }
@keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-8px)} 40%{transform:translateX(8px)} 60%{transform:translateX(-5px)} 80%{transform:translateX(5px)} }

/* QR MODAL */
#qrModal { display:none;position:fixed;inset:0;z-index:8888;background:rgba(13,10,26,.85);backdrop-filter:blur(12px);align-items:center;justify-content:center; }
#qrModal.show { display:flex; }
.qr-box { background:rgba(255,255,255,0.05);border:1px solid rgba(255,180,200,.25);border-radius:28px;padding:36px 40px;text-align:center;box-shadow:0 0 80px rgba(255,100,150,.18);animation:cardIn .6s cubic-bezier(.23,1,.32,1) both; }
.qr-title { font-family:‘Dancing Script’,cursive;font-size:22px;color:#ff9db8;margin-bottom:6px; }
.qr-sub { font-size:12px;color:rgba(255,180,200,.5);margin-bottom:20px;font-style:italic; }
#qrcode { display:inline-block;background:white;padding:12px;border-radius:16px;margin-bottom:20px; }
#qrcode canvas,#qrcode img { display:block!important; }
.qr-pass { font-family:‘Dancing Script’,cursive;font-size:18px;color:rgba(255,180,200,.6);margin-bottom:20px; }
.qr-close { background:linear-gradient(135deg,#ff6b9d,#c44569);border:none;border-radius:50px;padding:11px 32px;font-family:‘Dancing Script’,cursive;font-size:18px;color:white;cursor:pointer;box-shadow:0 4px 20px rgba(255,100,150,.35);transition:transform .2s; }
.qr-close:hover { transform:scale(1.05); }

/* STARS & AURORA */
.stars { position:fixed;inset:0;pointer-events:none;z-index:0; }
.star { position:absolute;border-radius:50%;background:white;animation:twinkle var(–d) ease-in-out infinite alternate; }
@keyframes twinkle { from{opacity:.1;transform:scale(.8)} to{opacity:.9;transform:scale(1.2)} }
.aurora { position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden; }
.aurora-band { position:absolute;border-radius:50%;filter:blur(80px);opacity:.12;animation:drift var(–dr) ease-in-out infinite alternate; }
@keyframes drift { from{transform:translate(0,0) scale(1)} to{transform:translate(var(–tx),var(–ty)) scale(1.15)} }
.heart-bg { position:fixed;inset:0;pointer-events:none;z-index:1;overflow:hidden; }
.heart-float { position:absolute;bottom:-50px;font-size:var(–fs);animation:floatUp var(–dur) linear infinite;animation-delay:var(–delay);opacity:0; }
@keyframes floatUp { 0%{opacity:0;transform:translateY(0) rotate(0deg)} 10%{opacity:.6} 90%{opacity:.4} 100%{opacity:0;transform:translateY(-110vh) rotate(360deg)} }

/* LAYOUT */
.container { position:relative;z-index:10;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px 60px;gap:0; }
.petals-top { position:relative;display:flex;justify-content:center;gap:8px;padding-bottom:18px;pointer-events:none; }
.petal { font-size:24px;animation:sway 3s ease-in-out infinite alternate;animation-delay:var(–d); }
@keyframes sway { from{transform:rotate(-10deg)} to{transform:rotate(10deg)} }

/* CARD */
.card { background:rgba(255,255,255,0.035);border:1px solid rgba(255,180,200,0.2);border-radius:36px;padding:50px 44px 44px;max-width:520px;width:100%;backdrop-filter:blur(24px);box-shadow:0 0 80px rgba(255,100,150,.12),0 0 200px rgba(180,60,120,.06),inset 0 0 50px rgba(255,150,180,.04);text-align:center;animation:cardIn 1.2s cubic-bezier(.23,1,.32,1) both; }

/* PROFILE */
.girl-wrap { position:relative;display:inline-block;margin-bottom:28px; }
.glow-ring { position:absolute;inset:-18px;border-radius:50%;background:conic-gradient(from 0deg,rgba(255,107,157,.5),rgba(255,180,200,.2),rgba(196,69,105,.5),rgba(255,107,157,.5));animation:spinGlow 6s linear infinite;filter:blur(10px); }
@keyframes spinGlow { to{transform:rotate(360deg)} }
.pulse-ring { position:absolute;inset:-8px;border-radius:50%;border:2px solid rgba(255,150,180,.4);animation:pulse 2.5s ease-in-out infinite; }
@keyframes pulse { 0%,100%{transform:scale(1);opacity:.5} 50%{transform:scale(1.08);opacity:1} }
.girl-img { width:190px;height:190px;border-radius:50%;object-fit:cover;object-position:top center;border:3px solid rgba(255,150,180,.6);box-shadow:0 0 40px rgba(255,100,150,.45);position:relative;z-index:2;display:block; }

/* STICKERS */
.stickers-row { display:flex;justify-content:center;gap:14px;margin:20px 0 10px;animation:fadeIn 1.5s 1.8s both; }
.sticker { width:90px;height:90px;object-fit:contain;filter:drop-shadow(0 4px 16px rgba(255,100,150,.35));transition:transform .3s;cursor:pointer;border-radius:12px; }
.sticker:hover { transform:scale(1.18) rotate(-5deg); }
.sticker:nth-child(2):hover { transform:scale(1.18) rotate(5deg); }
.sticker:nth-child(3):hover { transform:scale(1.18) rotate(-3deg); }

/* TEXT */
.tag { font-family:‘Dancing Script’,cursive;font-size:15px;color:#ff9db8;letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;animation:fadeIn 1.5s .5s both; }
.title { font-family:‘Cormorant Garamond’,serif;font-style:italic;font-size:clamp(27px,6vw,38px);color:#fff;line-height:1.3;margin-bottom:24px;animation:fadeIn 1.5s .7s both;text-shadow:0 0 40px rgba(255,150,180,.5); }
.divider { display:flex;align-items:center;gap:12px;margin:0 auto 24px;width:80%;animation:fadeIn 1.5s .9s both; }
.divider-line { flex:1;height:1px;background:linear-gradient(90deg,transparent,rgba(255,150,180,.5),transparent); }
.divider-heart { color:#ff6b9d;font-size:18px;animation:heartbeat 1.5s ease-in-out infinite; }
.message { font-size:clamp(15px,3.5vw,17px);color:rgba(255,220,230,.85);line-height:1.95;margin-bottom:30px;font-style:italic;animation:fadeIn 1.5s 1.1s both; }
.sub-message { font-family:‘Dancing Script’,cursive;font-size:22px;color:#ff9db8;margin-bottom:36px;animation:fadeIn 1.5s 1.3s both; }

/* YOUTUBE EMBED */
.yt-player-wrap { margin:0 0 28px;animation:fadeIn 1.5s 1.6s both;border-radius:20px;overflow:hidden;border:1px solid rgba(255,150,180,.2);box-shadow:0 0 30px rgba(255,100,150,.1); }
.yt-player-wrap iframe { display:block;width:100%;border:none; }

/* REVEAL */
.reveal-btn { background:linear-gradient(135deg,#ff6b9d,#c44569);border:none;border-radius:50px;padding:15px 44px;font-family:‘Dancing Script’,cursive;font-size:21px;color:white;cursor:pointer;box-shadow:0 8px 30px rgba(255,100,150,.4);transition:transform .2s,box-shadow .2s;animation:fadeIn 1.5s 1.5s both;position:relative;overflow:hidden; }
.reveal-btn::before { content:’’;position:absolute;top:-50%;left:-60%;width:60%;height:200%;background:rgba(255,255,255,.2);transform:skewX(-20deg);animation:shimmer 3s ease-in-out infinite; }
@keyframes shimmer { 0%{left:-60%} 100%{left:160%} }
.reveal-btn:hover { transform:translateY(-3px) scale(1.05);box-shadow:0 12px 40px rgba(255,100,150,.6); }
.reveal-btn:active { transform:scale(.97); }

.qr-btn { margin-top:20px;background:rgba(255,107,157,.1);border:1px solid rgba(255,150,180,.3);border-radius:50px;padding:10px 28px;font-family:‘Dancing Script’,cursive;font-size:17px;color:#ff9db8;cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:8px; }
.qr-btn:hover { background:rgba(255,107,157,.2);transform:scale(1.04);box-shadow:0 4px 20px rgba(255,100,150,.2); }

.secret { display:none;margin-top:30px;padding:30px;background:rgba(255,100,150,.08);border:1px solid rgba(255,150,180,.3);border-radius:24px;animation:secretReveal .8s cubic-bezier(.23,1,.32,1) both; }
.secret.show { display:block; }
@keyframes secretReveal { from{opacity:0;transform:scale(.8) translateY(20px)} to{opacity:1;transform:scale(1) translateY(0)} }
.secret-text { font-size:clamp(16px,3.5vw,19px);color:#ffe4ed;line-height:2;font-style:italic; }
.secret-sign { margin-top:18px;font-family:‘Dancing Script’,cursive;font-size:26px;color:#ff9db8; }

.burst { position:fixed;pointer-events:none;z-index:999;font-size:24px;animation:burst 1s ease-out forwards; }
@keyframes burst { 0%{opacity:1;transform:translate(0,0) scale(.5)} 100%{opacity:0;transform:translate(var(–tx),var(–ty)) scale(1.5)} }
@keyframes fadeIn { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:rgba(255,107,157,.3);border-radius:2px; }
</style>

</head>
<body>

<!-- QR MODAL -->

<div id="qrModal">
<div class="qr-box">
<div class="qr-title">📱 QR Код</div>
<div class="qr-sub">Утсаараа уншуулж нэвтэр</div>
<div id="qrcode"></div>
<div class="qr-pass" id="qrPassText">📱 Скан хийхэд <strong style="color:#ff9db8">шууд нэвтэрнэ</strong></div>
<button class="qr-close" onclick="document.getElementById('qrModal').classList.remove('show')">✕ Хаах</button>
</div>
</div>

<!-- LOGIN OVERLAY -->

<div id="loginOverlay">
<div class="login-stars" id="loginStars"></div>
<div class="login-card" id="loginCard">
<span class="login-icon">🔐</span>
<div class="login-title">Нэвтрэх</div>
<div class="login-sub">Зөвхөн чиний зориулсан... 🌸</div>
<div class="pin-container" id="pinDisplay">
<div class="pin-dot" id="d0">·</div>
<div class="pin-dot" id="d1">·</div>
<div class="pin-dot" id="d2">·</div>
<div class="pin-dot" id="d3">·</div>
</div>
<div class="numpad">
<button class="num-btn" onclick="enterPin('1')">1</button>
<button class="num-btn" onclick="enterPin('2')">2</button>
<button class="num-btn" onclick="enterPin('3')">3</button>
<button class="num-btn" onclick="enterPin('4')">4</button>
<button class="num-btn" onclick="enterPin('5')">5</button>
<button class="num-btn" onclick="enterPin('6')">6</button>
<button class="num-btn" onclick="enterPin('7')">7</button>
<button class="num-btn" onclick="enterPin('8')">8</button>
<button class="num-btn" onclick="enterPin('9')">9</button>
<button class="num-btn empty"></button>
<button class="num-btn" onclick="enterPin('0')">0</button>
<button class="num-btn del" onclick="deletePin()">⌫</button>
</div>
<div class="login-error" id="loginError"></div>
</div>
</div>

<!-- MAIN -->

<div class="stars" id="stars"></div>
<div class="aurora" id="aurora"></div>
<div class="heart-bg" id="heartBg"></div>

<div class="container" id="mainContent" style="display:none">
<div class="petals-top">
<span class="petal" style="--d:0s">🌸</span>
<span class="petal" style="--d:.3s">🌷</span>
<span class="petal" style="--d:.6s">🌸</span>
<span class="petal" style="--d:.9s">💮</span>
<span class="petal" style="--d:.4s">🌸</span>
<span class="petal" style="--d:.8s">🌷</span>
<span class="petal" style="--d:.2s">🌸</span>
</div>

<div class="card">
<!-- Profile photo -->
<div class="girl-wrap">
<div class="glow-ring"></div>
<div class="pulse-ring"></div>
<img class="girl-img" id="mainPhoto" src="data:image/jpeg;base64," alt="Чи">
</div>

```
<div class="tag">✦ Чамд зориулсан ✦</div>
<h1 class="title">Чиний тухай<br>бодохоо болиогүй нэгэн...</h1>
<div class="divider">
<div class="divider-line"></div>
<span class="divider-heart">♥</span>
<div class="divider-line"></div>
</div>

<p class="message">
Цэцэг өгсөнд баярлалаа<br>
ямар ч хүлээлтгүй байхад<br>
үнэхээр гэнтийн байсан шүү.<br>
нэг тэнэг ч юм шиг гэнэтийн зүйл хэлэх гэсэн.
</p>

<!-- Stickers row -->
<div class="stickers-row">
<img class="sticker" src="data:image/jpeg;base64," alt="😕" title="Хэмбэй">
<img class="sticker" src="data:image/jpeg;base64," alt="😊" title="Баяртай">
<img class="sticker" src="data:image/jpeg;base64," alt="😔" title="Гунигтай">
</div>

<!-- YouTube embed — autoplay 1:36 (96s) to 2:08 (128s) -->
<div class="yt-player-wrap">
<iframe id="ytFrame"
src="https://www.youtube.com/embed/waDMLxzfzs0?start=96&end=128&autoplay=1&loop=1&playlist=waDMLxzfzs0&controls=1&modestbranding=1&rel=0&enablejsapi=1"
width="100%" height="80"
allow="autoplay; encrypted-media"
allowfullscreen>
</iframe>
</div>

<p class="sub-message">Нэг зүйл хэлэх гэсэн юм... 💕</p>
<button class="reveal-btn" onclick="revealSecret(event)">❤️ Сэтгэлийг нээ</button>

<div class="secret" id="secret">
<p class="secret-text">
Чамайг анх харснаас хойш<br>
цаанаасаа л бага багаар...<br><br>
өдөр бүрээр татагдаж байсан<br>
маш олон алдаа хийсэнд уучлаарай хэлье гэж бодсон ч ,<br>
амаараа хэлж чадахгүй байгаад уучлаарай хэлэх юм байвал шууд чат бичээрэй эсүүл намайг иртэл хүлээгээрэй.<br><br>
<strong style="color:#ff9db8">Би чамд дуртай.</strong> 🌸
</p>
<p class="secret-sign">— Зүрхнийхээ гүнээс ♡</p>
</div>

<button class="qr-btn" onclick="showQR()">📱 QR код үүсгэх</button>
```

</div>
</div>

<script>
// QR auto-unlock
(function() {
const params = new URLSearchParams(window.location.search);
if (params.get('open') === '1') {
const overlay = document.getElementById('loginOverlay');
const card = document.getElementById('loginCard');
card.innerHTML = `
<span style="font-size:64px;display:block;margin-bottom:12px;animation:heartbeat 1s ease-in-out infinite">🌸</span>
<div style="font-family:'Dancing Script',cursive;font-size:28px;color:#fff;margin-bottom:8px">Тавтай морил...</div>
<div style="font-size:13px;color:rgba(255,180,200,.6);font-style:italic">Чиний зориулсан зай нээгдэж байна ✨</div>
`;
setTimeout(() => {
overlay.style.transition = 'opacity 1s ease';
overlay.style.opacity = '0';
setTimeout(() => {
overlay.style.display = 'none';
document.getElementById('mainContent').style.display = 'flex';
initMain();
}, 1000);
}, 1400);
return;
}
})();

// Login
const CORRECT_PIN = '0000';
let currentPin = '';
const loginStars = document.getElementById('loginStars');
for (let i = 0; i < 100; i++) {
const s = document.createElement('div'); s.className = 'star';
const size = Math.random()*2.5+0.8;
s.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--d:${Math.random()*4+2}s;animation-delay:${Math.random()*4}s;`;
loginStars.appendChild(s);
}
function updatePinDisplay() {
for (let i=0;i<4;i++) {
const dot=document.getElementById('d'+i);
if(i<currentPin.length){dot.textContent='♥';dot.classList.add('filled');}
else{dot.textContent='·';dot.classList.remove('filled');}
}
}
function enterPin(digit) {
if(currentPin.length>=4) return;
currentPin+=digit; updatePinDisplay();
document.getElementById('loginError').textContent='';
if(currentPin.length===4) setTimeout(()=>{
if(currentPin===CORRECT_PIN) unlockSite();
else{showLoginError();currentPin='';updatePinDisplay();}
},300);
}
function deletePin(){currentPin=currentPin.slice(0,-1);updatePinDisplay();document.getElementById('loginError').textContent='';}
function showLoginError(){
const card=document.getElementById('loginCard'),err=document.getElementById('loginError');
err.textContent='❌ Буруу нууц үг, дахин оруул';
card.classList.add('shake');setTimeout(()=>card.classList.remove('shake'),400);
}
function unlockSite(){
const overlay=document.getElementById('loginOverlay');
overlay.style.transition='opacity 0.8s ease';overlay.style.opacity='0';
setTimeout(()=>{overlay.style.display='none';document.getElementById('mainContent').style.display='flex';initMain();},800);
}

function initMain() {
const starsEl=document.getElementById('stars');
for(let i=0;i<140;i++){
const s=document.createElement('div');s.className='star';
const size=Math.random()*3+1;
s.style.cssText=`width:${size}px;height:${size}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--d:${Math.random()*4+2}s;animation-delay:${Math.random()*4}s;`;
starsEl.appendChild(s);
}
const aurora=document.getElementById('aurora');
[{w:700,h:500,t:'10%',l:'20%',bg:'rgba(255,100,150,1)',dr:'12s',tx:'80px',ty:'40px'},
{w:500,h:400,t:'50%',l:'60%',bg:'rgba(150,50,200,1)',dr:'15s',tx:'-60px',ty:'80px'},
{w:600,h:350,t:'30%',l:'-10%',bg:'rgba(255,150,100,1)',dr:'10s',tx:'40px',ty:'-60px'}
].forEach(b=>{
const d=document.createElement('div');d.className='aurora-band';
d.style.cssText=`width:${b.w}px;height:${b.h}px;top:${b.t};left:${b.l};background:${b.bg};--dr:${b.dr};--tx:${b.tx};--ty:${b.ty};`;
aurora.appendChild(d);
});
const heartBg=document.getElementById('heartBg');
const emojis=['💕','💗','💓','💞','🌸','✨','💖','🌷'];
for(let i=0;i<22;i++){
const h=document.createElement('div');h.className='heart-float';
h.textContent=emojis[Math.floor(Math.random()*emojis.length)];
h.style.cssText=`left:${Math.random()*100}%;--fs:${Math.random()*18+12}px;--dur:${Math.random()*10+8}s;--delay:${Math.random()*10}s;`;
heartBg.appendChild(h);
}
}

function revealSecret(e){
const secret=document.getElementById('secret');
secret.classList.toggle('show');
const btn=e.currentTarget;
if(secret.classList.contains('show')){btn.textContent='🌸 Нуух';createBurst(e.clientX,e.clientY);}
else{btn.textContent='❤️ Сэтгэлийг нээ';}
}

function showQR(){
const modal=document.getElementById('qrModal');
document.getElementById('qrcode').innerHTML='';
const base=window.location.href.split('?')[0];
const qrUrl=base+'?open=1';
new QRCode(document.getElementById('qrcode'),{text:qrUrl,width:200,height:200,colorDark:'#1a0a15',colorLight:'#ffffff',correctLevel:QRCode.CorrectLevel.M});
modal.classList.add('show');
}
document.getElementById('qrModal').addEventListener('click',(e)=>{
if(e.target===document.getElementById('qrModal')) document.getElementById('qrModal').classList.remove('show');
});

function createBurst(x,y){
const hearts=['💕','💗','💖','💓','✨','🌸'];
for(let i=0;i<14;i++){
const el=document.createElement('div');el.className='burst';
el.textContent=hearts[Math.floor(Math.random()*hearts.length)];
const angle=(Math.PI*2*i)/14,dist=80+Math.random()*80;
el.style.cssText=`left:${x}px;top:${y}px;--tx:${Math.cos(angle)*dist}px;--ty:${Math.sin(angle)*dist}px;`;
document.body.appendChild(el);setTimeout(()=>el.remove(),1100);
}
}
document.addEventListener('click',(e)=>{
if(document.getElementById('mainContent').style.display==='none') return;
if(e.target.closest('.reveal-btn')||e.target.closest('.qr-btn')||e.target.closest('#qrModal')) return;
const el=document.createElement('div');el.className='burst';
el.textContent=['💕','💗','✨'][Math.floor(Math.random()*3)];
el.style.cssText=`left:${e.clientX}px;top:${e.clientY}px;font-size:16px;--tx:${(Math.random()-.5)*60}px;--ty:${-40-Math.random()*40}px;`;
document.body.appendChild(el);setTimeout(()=>el.remove(),1000);
});
</script>

</body>
</html>
